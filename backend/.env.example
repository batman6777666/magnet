# ── Server ──────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── API Keys (comma-separated, no spaces) ───────────
# Keys are auto-generated via POST /auth/register
# Format: mk-{timestamp}-{random}-{checksum} (e.g. mk-m5z8abc-def1234567890abcdef1234567890-a1b2c3d4)
API_KEYS=mk-your_key_here

# ── Browser Pool ─────────────────────────────────────
BROWSER_POOL_SIZE=5

# ── Timeouts (milliseconds) ──────────────────────────
PAGE_LOAD_TIMEOUT_MS=6000
TOTAL_REQUEST_TIMEOUT_MS=12000

# ── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
